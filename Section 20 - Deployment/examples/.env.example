# .env.example
# Copy this file to ".env" and fill in real values.
# In Vite, variables MUST start with VITE_ to be readable in the app.
# Read them with import.meta.env.VITE_API_URL
#
# WARNING: frontend env vars are visible to users in the browser.
# Never put private secrets here. Public values only.

VITE_API_URL=https://jsonplaceholder.typicode.com
